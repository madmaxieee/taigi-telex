<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>CFBundleIdentifier</key>
    <string>com.kahiok.inputmethod.TaigiTelex</string>
    <key>CFBundleName</key>
    <string>TaigiTelex</string>
    <key>NSPrincipalClass</key>
    <string>TaigiTelex.NSManualApplication</string>
    <key>InputMethodConnectionName</key>
    <string>com.kahiok.inputmethod.TaigiTelex_Connection</string>
    <key>InputMethodServerControllerClass</key>
    <string>TaigiTelex.TaigiTelexInputController</string>
    <key>LSBackgroundOnly</key>
    <true />
    <key>TISInputSourceID</key>
    <string>com.kahiok.inputmethod.TaigiTelex</string>
    <key>TICapsLockLanguageSwitchCapable</key>
    <true />
    <!-- pretend to be Chinese input method to get capslock switching to and from english working -->
    <key>TISIntendedLanguage</key>
    <string>zh-Hant</string>
    <key>ComponentInputModeDict</key>
    <dict>
      <key>tsInputModeListKey</key>
      <dict>
        <key>com.kahiok.inputmethod.TaigiTelexTL</key>
        <dict>
          <key>TISDoubleSpaceSubstitution</key>
          <string>. </string>
          <key>tsInputModeIsVisibleKey</key>
          <true />
          <key>tsInputModeMenuIconFileKey</key>
          <string>TW-input-menu.tiff</string>
          <key>tsInputModePaletteIconFileKey</key>
          <string>TW-input-menu.tiff</string>
        </dict>
      </dict>
    </dict>
    <key>tsInputMethodCharacterRepertoireKey</key>
    <array>
      <string>Latn</string>
    </array>
    <key>tsInputMethodIconFileKey</key>
    <string>TW-preference.tiff</string>
  </dict>
</plist>
